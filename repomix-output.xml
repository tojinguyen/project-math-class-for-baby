.sbs-val.bump{animation:scoreBump .3s ease}

.student-body{flex:1;max-width:680px;margin:0 auto;width:100%;padding:16px 16px 40px}

/* Student waiting */
.student-waiting{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  min-height:50vh;gap:16px;text-align:center;
}
.sw-icon{font-size:56px;animation:detFloat 2s ease-in-out infinite}
.sw-title{font-family:var(--font-title);font-size:24px;letter-spacing:2px;color:var(--white)}
.sw-sub{font-size:13px;font-weight:700;color:var(--white-dim)}
.sw-dots{display:flex;gap:6px;justify-content:center;margin-top:4px}
.sw-dot{width:8px;height:8px;border-radius:50%;background:var(--yellow);animation:dotPulse 1.4s infinite}
.sw-dot:nth-child(2){animation-delay:.2s}.sw-dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{0%,100%{opacity:.3;transform:scale(.8)}50%{opacity:1;transform:scale(1)}}

/* Student question card */
.student-q-card{
