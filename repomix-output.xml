}
.student-feedback.show{display:flex}
.student-feedback.sf-correct{background:rgba(46,213,115,.08);border:2px solid rgba(46,213,115,.25)}
.student-feedback.sf-wrong  {background:rgba(255,71,87,.08); border:2px solid rgba(255,71,87,.2)}
.student-feedback.sf-wait   {background:rgba(245,197,24,.06);border:2px solid rgba(245,197,24,.15)}
.sff-icon{font-size:20px;flex-shrink:0}
.sff-body{font-size:13px;font-weight:700;color:var(--white-dim);line-height:1.7}
.sff-body strong{color:var(--white)}

/* Student correction */
.student-correction{
  margin-top:14px;padding:14px 16px;
  background:rgba(245,197,24,.04);border:2px dashed rgba(245,197,24,.2);border-radius:10px;
  display:none;
}
.student-correction.show{display:block}
.sc-title{font-family:var(--font-title);font-size:14px;letter-spacing:2px;color:var(--yellow);margin-bottom:10px}
.sc-wrong{font-family:var(--font-mono);font-size:15px;color:var(--red);text-decoration:line-through;text-decoration-thickness:2px;margin-bottom:12px;padding:6px 10px;background:rgba(255,71,87,.07);border-radius:6px;display:inline-block;border:1px solid rgba(255,71,87,.2)}
.sc-wrong mark{background:rgba(255,71,87,.2);color:var(--red);border-radius:4px;padding:1px 5px;text-decoration:line-through;text-decoration-color:var(--red)}

/* Attempt counter */
.student-attempts{display:flex;align-items:center;gap:5px;margin-top:12px}
.sa-label{font-size:10px;font-weight:800;letter-spacing:1px;color:var(--white-ghost)}

/* Waiting for others overlay */
.waiting-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.7);
  backdrop-filter:blur(6px);z-index:500;
  display:none;align-items:center;justify-content:center;flex-direction:column;gap:12px;
}
.waiting-overlay.show{display:flex}
.wo-icon{font-size:48px;animation:detFloat 2s ease-in-out infinite}
.wo-title{font-family:var(--font-title);font-size:22px;letter-spacing:2px;color:var(--white);text-align:center}
.wo-sub{font-size:13px;font-weight:700;color:var(--white-dim)}
.wo-score{
  background:var(--panel);border:2px solid var(--yellow);border-radius:12px;
  padding:12px 28px;text-align:center;margin-top:8px;
}
.wo-pts{font-family:var(--font-title);font-size:48px;color:var(--yellow);line-height:1}
.wo-pts-label{font-size:11px;font-weight:800;letter-spacing:2px;color:var(--yellow-dim)}

@media(max-width:700px){
  .host-game-area{grid-template-columns:1fr}
  .host-scoreboard-col{display:none}
  .hwcd-code{font-size:52px;letter-spacing:6px}
  .student-solution .token{font-size:15px}
}
