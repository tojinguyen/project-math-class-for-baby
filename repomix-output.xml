.hsb-name{flex:1;font-size:13px;font-weight:800;color:var(--white);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hsb-status{font-size:16px;flex-shrink:0}
.hsb-score{font-family:var(--font-title);font-size:20px;color:var(--yellow);flex-shrink:0}

/* Live answer flash */
.hsb-row.flash-correct{animation:rowFlash .6s ease}
@keyframes rowFlash{0%{background:rgba(46,213,115,.3)}100%{background:rgba(46,213,115,.06)}}

/* Host controls bar */
.host-ctrl-bar{
  background:rgba(12,10,8,.95);border-top:2px solid var(--border);
