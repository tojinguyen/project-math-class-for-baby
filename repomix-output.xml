/* Answer progress bar */
.ans-progress{
  height:4px;background:var(--space2);margin:0 24px 0;
}
.ans-progress-fill{
  height:100%;background:linear-gradient(90deg,var(--green),#7bed9f);
  transition:width .4s ease;border-radius:2px;
}

/* ══ STUDENT VIEW ══ */
#screen-student{flex-direction:column;min-height:100vh;background:var(--space)}
